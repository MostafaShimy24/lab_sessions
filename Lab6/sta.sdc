# ============================================================
# CLOCK
# ============================================================
create_clock -name clk -period 10 [get_ports clk]

# Small transition for realism
set_clock_transition 0.1 [get_clocks clk]

# ============================================================
# INPUT DELAYS 
# ============================================================
set_input_delay 2.0 -clock clk \
    [get_ports {in[*] shift_amt[*] is_sync}]

# ============================================================
# OUTPUT DELAY 
# ============================================================
set_output_delay 2.0 -clock clk [get_ports y]

# ============================================================
# OUTPUT LOAD
# ============================================================
set_load 0.05 [get_ports y]

# ============================================================
# INPUT DRIVER
# ============================================================
set_driving_cell -lib_cell sky130_fd_sc_hd__inv_2 \
    [get_ports {in[*] shift_amt[*] is_sync}]

# ============================================================
# RESET 
# ============================================================
set_false_path -from [get_ports rst_n]

# ============================================================
# END
# ============================================================