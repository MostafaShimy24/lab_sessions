      NEW met1 ( 13110 15470 ) ( * 15810 )
      NEW met1 ( 13110 15810 ) ( 17250 * )
      NEW li1 ( 17250 12070 ) L1M1_PR_MR
      NEW met1 ( 17250 12070 ) M1M2_PR
      NEW met1 ( 17250 19550 ) M1M2_PR
      NEW li1 ( 20010 19550 ) L1M1_PR_MR
      NEW li1 ( 13110 15470 ) L1M1_PR_MR
      NEW met1 ( 17250 15810 ) M1M2_PR ;
    - in[0] ( PIN in[0] ) ( _1_ B ) + USE SIGNAL
      + ROUTED met2 ( 16790 340 0 ) ( * 17510 )
      NEW met1 ( 16790 17510 ) ( 17250 * )
      NEW met1 ( 16790 17510 ) M1M2_PR
      NEW li1 ( 17250 17510 ) L1M1_PR_MR ;
    - in[1] ( PIN in[1] ) ( _1_ A ) + USE SIGNAL
      + ROUTED met2 ( 18630 340 0 ) ( * 9180 )
      NEW met2 ( 18170 9180 ) ( 18630 * )
      NEW met2 ( 18170 9180 ) ( * 17850 )
      NEW met1 ( 16330 17850 ) ( 18170 * )
      NEW met1 ( 18170 17850 ) M1M2_PR
      NEW li1 ( 16330 17850 ) L1M1_PR_MR ;
    - is_sync ( PIN is_sync ) ( _3_ S ) + USE SIGNAL
      + ROUTED met2 ( 14950 340 0 ) ( * 12410 )
      NEW met1 ( 14950 12410 ) ( 18170 * )
      NEW met1 ( 14950 12410 ) M1M2_PR
      NEW li1 ( 18170 12410 ) L1M1_PR_MR ;
    - rst_n ( PIN rst_n ) ( _4_ RESET_B ) + USE SIGNAL
      + ROUTED met2 ( 14030 340 0 ) ( * 7820 )
      NEW met2 ( 14030 7820 ) ( 14490 * )
      NEW met2 ( 14490 7820 ) ( * 15470 )
      NEW met1 ( 14490 15470 ) ( 15410 * 0 )
      NEW met1 ( 14490 15470 ) M1M2_PR ;
    - shift_amt[0] ( PIN shift_amt[0] ) ( _1_ C ) + USE SIGNAL
      + ROUTED met2 ( 17710 340 0 ) ( * 17170 )
      NEW met1 ( 17710 17170 ) ( 18170 * )
      NEW met1 ( 17710 17170 ) M1M2_PR
      NEW li1 ( 18170 17170 ) L1M1_PR_MR ;
    - shift_amt[1] ( PIN shift_amt[1] ) ( _2_ A ) + USE SIGNAL
      + ROUTED met2 ( 19550 340 0 ) ( * 20570 )
      NEW met1 ( 18170 20570 ) ( 19550 * )
      NEW met1 ( 19550 20570 ) M1M2_PR
      NEW li1 ( 18170 20570 ) L1M1_PR_MR ;
    - y ( PIN y ) ( _3_ X ) + USE SIGNAL
      + ROUTED met2 ( 15870 340 0 ) ( * 11390 )
      NEW met1 ( 15410 11390 ) ( 15870 * )
      NEW met1 ( 15870 11390 ) M1M2_PR
      NEW li1 ( 15410 11390 ) L1M1_PR_MR ;
    - y_reg ( _4_ Q ) ( _3_ A1 ) + USE SIGNAL
      + ROUTED met1 ( 17710 12070 ) ( 20470 * )
      NEW met2 ( 20470 12070 ) ( * 14110 )
      NEW li1 ( 17710 12070 ) L1M1_PR_MR
      NEW met1 ( 20470 12070 ) M1M2_PR
      NEW li1 ( 20470 14110 ) L1M1_PR_MR
      NEW met1 ( 20470 14110 ) M1M2_PR ;
END NETS
END DESIGN
