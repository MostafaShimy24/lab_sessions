      NEW met1 ( 11730 14110 ) ( * 14790 )
      NEW met1 ( 13110 14110 ) M1M2_PR
      NEW li1 ( 11730 14790 ) L1M1_PR_MR ;
    - comb_y ( _4_ D ) ( _3_ A0 ) ( _2_ X ) + USE SIGNAL
