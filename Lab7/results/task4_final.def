    - FILLER_2_24 sky130_fd_sc_hd__fill_2 + SOURCE DIST + PLACED ( 21160 16320 ) N ;
    - FILLER_2_3 sky130_fd_sc_hd__fill_8 + SOURCE DIST + PLACED ( 11500 16320 ) N ;
    - FILLER_3_11 sky130_fd_sc_hd__fill_4 + SOURCE DIST + PLACED ( 15180 19040 ) FS ;
    - FILLER_3_22 sky130_fd_sc_hd__fill_4 + SOURCE DIST + PLACED ( 20240 19040 ) FS ;
    - FILLER_3_3 sky130_fd_sc_hd__fill_8 + SOURCE DIST + PLACED ( 11500 19040 ) FS ;
    - PHY_EDGE_ROW_0_Left_4 sky130_fd_sc_hd__decap_3 + SOURCE DIST + FIXED ( 10120 10880 ) N ;
    - PHY_EDGE_ROW_0_Right_0 sky130_fd_sc_hd__decap_3 + SOURCE DIST + FIXED ( 22080 10880 ) FN ;
    - PHY_EDGE_ROW_1_Left_5 sky130_fd_sc_hd__decap_3 + SOURCE DIST + FIXED ( 10120 13600 ) FS ;
    - PHY_EDGE_ROW_1_Right_1 sky130_fd_sc_hd__decap_3 + SOURCE DIST + FIXED ( 22080 13600 ) S ;
    - PHY_EDGE_ROW_2_Left_6 sky130_fd_sc_hd__decap_3 + SOURCE DIST + FIXED ( 10120 16320 ) N ;
    - PHY_EDGE_ROW_2_Right_2 sky130_fd_sc_hd__decap_3 + SOURCE DIST + FIXED ( 22080 16320 ) FN ;
    - PHY_EDGE_ROW_3_Left_7 sky130_fd_sc_hd__decap_3 + SOURCE DIST + FIXED ( 10120 19040 ) FS ;
    - PHY_EDGE_ROW_3_Right_3 sky130_fd_sc_hd__decap_3 + SOURCE DIST + FIXED ( 22080 19040 ) S ;
    - _1_ sky130_fd_sc_hd__maj3_1 + PLACED ( 15640 16320 ) N ;
    - _2_ sky130_fd_sc_hd__xor2_1 + PLACED ( 17020 19040 ) FS ;
    - _3_ sky130_fd_sc_hd__mux2_1 + PLACED ( 15180 10880 ) N ;
    - _4_ sky130_fd_sc_hd__dfrtp_1 + PLACED ( 11500 13600 ) FS ;
END COMPONENTS
PINS 8 ;
    - clk + NET clk + DIRECTION INPUT + USE SIGNAL
      + PORT
        + LAYER met2 ( -70 -242 ) ( 70 243 )
        + PLACED ( 13110 242 ) N ;
    - in[0] + NET in[0] + DIRECTION INPUT + USE SIGNAL
      + PORT
        + LAYER met2 ( -70 -242 ) ( 70 243 )
        + PLACED ( 16790 242 ) N ;
    - in[1] + NET in[1] + DIRECTION INPUT + USE SIGNAL
      + PORT
        + LAYER met2 ( -70 -242 ) ( 70 243 )
        + PLACED ( 18630 242 ) N ;
    - is_sync + NET is_sync + DIRECTION INPUT + USE SIGNAL
      + PORT
        + LAYER met2 ( -70 -242 ) ( 70 243 )
        + PLACED ( 14950 242 ) N ;
    - rst_n + NET rst_n + DIRECTION INPUT + USE SIGNAL
      + PORT
        + LAYER met2 ( -70 -242 ) ( 70 243 )
        + PLACED ( 14030 242 ) N ;
    - shift_amt[0] + NET shift_amt[0] + DIRECTION INPUT + USE SIGNAL
      + PORT
        + LAYER met2 ( -70 -242 ) ( 70 243 )
        + PLACED ( 17710 242 ) N ;
    - shift_amt[1] + NET shift_amt[1] + DIRECTION INPUT + USE SIGNAL
      + PORT
        + LAYER met2 ( -70 -242 ) ( 70 243 )
        + PLACED ( 19550 242 ) N ;
    - y + NET y + DIRECTION OUTPUT + USE SIGNAL
      + PORT
        + LAYER met2 ( -70 -242 ) ( 70 243 )
        + PLACED ( 15870 242 ) N ;
END PINS
SPECIALNETS 2 ;
    - VGND ( * VNB ) ( * VGND ) + USE GROUND
      + ROUTED met1 480 + SHAPE FOLLOWPIN ( 10120 21760 ) ( 23460 21760 )
      NEW met1 480 + SHAPE FOLLOWPIN ( 10120 16320 ) ( 23460 16320 )
      NEW met1 480 + SHAPE FOLLOWPIN ( 10120 10880 ) ( 23460 10880 ) ;
    - VPWR ( * VPB ) ( * VPWR ) + USE POWER
      + ROUTED met1 480 + SHAPE FOLLOWPIN ( 10120 19040 ) ( 23460 19040 )
      NEW met1 480 + SHAPE FOLLOWPIN ( 10120 13600 ) ( 23460 13600 ) ;
END SPECIALNETS
NETS 11 ;
    - _0_ ( _2_ B ) ( _1_ X ) + USE SIGNAL
      + ROUTED met2 ( 19090 18530 ) ( * 20230 )
      NEW met1 ( 18630 20230 ) ( 19090 * )
      NEW li1 ( 19090 18530 ) L1M1_PR_MR
      NEW met1 ( 19090 18530 ) M1M2_PR
      NEW met1 ( 19090 20230 ) M1M2_PR
      NEW li1 ( 18630 20230 ) L1M1_PR_MR ;
    - clk ( PIN clk ) ( _4_ CLK ) + USE CLOCK
      + ROUTED met2 ( 13110 340 0 ) ( * 14110 )
