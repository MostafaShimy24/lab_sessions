VERSION 5.8 ;
DIVIDERCHAR "/" ;
BUSBITCHARS "[]" ;
DESIGN LUT ;
UNITS DISTANCE MICRONS 1000 ;
DIEAREA ( 0 0 ) ( 33545 33545 ) ;
ROW ROW_0 unithd 10120 10880 N DO 29 BY 1 STEP 460 0 ;
ROW ROW_1 unithd 10120 13600 FS DO 29 BY 1 STEP 460 0 ;
ROW ROW_2 unithd 10120 16320 N DO 29 BY 1 STEP 460 0 ;
ROW ROW_3 unithd 10120 19040 FS DO 29 BY 1 STEP 460 0 ;
TRACKS X 230 DO 73 STEP 460 LAYER li1 ;
TRACKS Y 170 DO 98 STEP 340 LAYER li1 ;
TRACKS X 170 DO 98 STEP 340 LAYER met1 ;
TRACKS Y 170 DO 98 STEP 340 LAYER met1 ;
TRACKS X 230 DO 73 STEP 460 LAYER met2 ;
TRACKS Y 230 DO 73 STEP 460 LAYER met2 ;
TRACKS X 340 DO 49 STEP 680 LAYER met3 ;
TRACKS Y 340 DO 49 STEP 680 LAYER met3 ;
TRACKS X 460 DO 36 STEP 920 LAYER met4 ;
TRACKS Y 460 DO 36 STEP 920 LAYER met4 ;
TRACKS X 1700 DO 10 STEP 3400 LAYER met5 ;
TRACKS Y 1700 DO 10 STEP 3400 LAYER met5 ;
COMPONENTS 12 ;
    - PHY_EDGE_ROW_0_Left_4 sky130_fd_sc_hd__decap_3 + SOURCE DIST + FIXED ( 10120 10880 ) N ;
    - PHY_EDGE_ROW_0_Right_0 sky130_fd_sc_hd__decap_3 + SOURCE DIST + FIXED ( 22080 10880 ) FN ;
    - PHY_EDGE_ROW_1_Left_5 sky130_fd_sc_hd__decap_3 + SOURCE DIST + FIXED ( 10120 13600 ) FS ;
    - PHY_EDGE_ROW_1_Right_1 sky130_fd_sc_hd__decap_3 + SOURCE DIST + FIXED ( 22080 13600 ) S ;
    - PHY_EDGE_ROW_2_Left_6 sky130_fd_sc_hd__decap_3 + SOURCE DIST + FIXED ( 10120 16320 ) N ;
    - PHY_EDGE_ROW_2_Right_2 sky130_fd_sc_hd__decap_3 + SOURCE DIST + FIXED ( 22080 16320 ) FN ;
    - PHY_EDGE_ROW_3_Left_7 sky130_fd_sc_hd__decap_3 + SOURCE DIST + FIXED ( 10120 19040 ) FS ;
    - PHY_EDGE_ROW_3_Right_3 sky130_fd_sc_hd__decap_3 + SOURCE DIST + FIXED ( 22080 19040 ) S ;
    - _1_ sky130_fd_sc_hd__maj3_1 ;
    - _2_ sky130_fd_sc_hd__xor2_1 ;
    - _3_ sky130_fd_sc_hd__mux2_1 ;
    - _4_ sky130_fd_sc_hd__dfrtp_1 ;
END COMPONENTS
PINS 8 ;
    - clk + NET clk + DIRECTION INPUT + USE SIGNAL
      + PORT
        + LAYER met2 ( -70 -242 ) ( 70 243 )
        + PLACED ( 13110 242 ) N ;
    - in[0] + NET in[0] + DIRECTION INPUT + USE SIGNAL
      + PORT
        + LAYER met2 ( -70 -242 ) ( 70 243 )
        + PLACED ( 16790 242 ) N ;
    - in[1] + NET in[1] + DIRECTION INPUT + USE SIGNAL
      + PORT
        + LAYER met2 ( -70 -242 ) ( 70 243 )
        + PLACED ( 18630 242 ) N ;
    - is_sync + NET is_sync + DIRECTION INPUT + USE SIGNAL
      + PORT
        + LAYER met2 ( -70 -242 ) ( 70 243 )
        + PLACED ( 14950 242 ) N ;
    - rst_n + NET rst_n + DIRECTION INPUT + USE SIGNAL
      + PORT
        + LAYER met2 ( -70 -242 ) ( 70 243 )
        + PLACED ( 14030 242 ) N ;
    - shift_amt[0] + NET shift_amt[0] + DIRECTION INPUT + USE SIGNAL
      + PORT
        + LAYER met2 ( -70 -242 ) ( 70 243 )
        + PLACED ( 17710 242 ) N ;
    - shift_amt[1] + NET shift_amt[1] + DIRECTION INPUT + USE SIGNAL
      + PORT
        + LAYER met2 ( -70 -242 ) ( 70 243 )
        + PLACED ( 19550 242 ) N ;
    - y + NET y + DIRECTION OUTPUT + USE SIGNAL
      + PORT
        + LAYER met2 ( -70 -242 ) ( 70 243 )
        + PLACED ( 15870 242 ) N ;
END PINS
SPECIALNETS 2 ;
    - VGND ( * VNB ) ( * VGND ) + USE GROUND
      + ROUTED met1 480 + SHAPE FOLLOWPIN ( 10120 21760 ) ( 23460 21760 )
      NEW met1 480 + SHAPE FOLLOWPIN ( 10120 16320 ) ( 23460 16320 )
      NEW met1 480 + SHAPE FOLLOWPIN ( 10120 10880 ) ( 23460 10880 ) ;
    - VPWR ( * VPB ) ( * VPWR ) + USE POWER
      + ROUTED met1 480 + SHAPE FOLLOWPIN ( 10120 19040 ) ( 23460 19040 )
      NEW met1 480 + SHAPE FOLLOWPIN ( 10120 13600 ) ( 23460 13600 ) ;
END SPECIALNETS
NETS 13 ;
    - _0_ ( _2_ B ) ( _1_ X ) + USE SIGNAL ;
    - clk ( PIN clk ) ( _4_ CLK ) + USE SIGNAL ;
    - comb_y ( _4_ D ) ( _3_ A0 ) ( _2_ X ) + USE SIGNAL ;
    - in[0] ( PIN in[0] ) ( _1_ B ) + USE SIGNAL ;
    - in[1] ( PIN in[1] ) ( _1_ A ) + USE SIGNAL ;
    - is_sync ( PIN is_sync ) ( _3_ S ) + USE SIGNAL ;
    - one_ + USE POWER ;
    - rst_n ( PIN rst_n ) ( _4_ RESET_B ) + USE SIGNAL ;
    - shift_amt[0] ( PIN shift_amt[0] ) ( _1_ C ) + USE SIGNAL ;
    - shift_amt[1] ( PIN shift_amt[1] ) ( _2_ A ) + USE SIGNAL ;
    - y ( PIN y ) ( _3_ X ) + USE SIGNAL ;
    - y_reg ( _4_ Q ) ( _3_ A1 ) + USE SIGNAL ;
    - zero_ + USE GROUND ;
END NETS
END DESIGN
