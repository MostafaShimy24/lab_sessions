[options]
mode cover
depth 30
append 5

[engines]
smtbmc z3

[script]
read -formal id_ex_formal.sv
read -formal -D FORMAL id_ex_wrapper.v
read -formal id_stage.v
read -formal ex_stage.v
read -formal regfile.v
read -formal alu.v
read -formal conv_pe.v
prep -top id_ex_wrapper -flatten

[files]
id_ex_formal.sv
id_ex_wrapper.v
id_stage.v
ex_stage.v
regfile.v
alu.v
conv_pe.v
